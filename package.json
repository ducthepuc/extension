{
  "name": "roblox-builder-rules",
  "displayName": "Roblox Builder Rules",
  "description": "Deprecation-aware linting for Roblox Luau workspaces",
  "version": "1.0.0",
  "private": true,
  "publisher": "roblox-builder-rules",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ducthepuc/extension.git"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "workspaceContains:default.project.json",
    "workspaceContains:*.project.json",
    "onLanguage:lua",
    "onLanguage:luau",
    "onView:builder.apipediaView"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "bun build src/extension.ts --outdir out --target node --external vscode",
    "watch": "bun build src/extension.ts --outdir out --target node --external vscode --watch",
    "lint": "tsc --noEmit",
    "scrape": "bun scripts/compile-rules.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/vscode": "1.85.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "roblox-builder-rules.syncRules",
        "title": "Roblox Builder Rules: Sync rules cache"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "builder-apipedia",
          "title": "Builder APIpedia",
          "icon": "media/apipedia-icon.svg"
        }
      ]
    },
    "views": {
      "builder-apipedia": [
        {
          "type": "webview",
          "id": "builder.apipediaView",
          "name": "Builder APIpedia"
        }
      ]
    }
  }
}
